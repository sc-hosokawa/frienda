COMPOSE_PROJECT_NAME=frienda-dev
# PostgreSQL connection settings (shared by Makefile and Docker Compose)
# PG_HOST is used by Makefile only (psql/pg_dump connect to this host)
# PG_PORT, PG_USER, PG_PASSWORD, PG_DB are used by both Makefile and Docker Compose
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB=postgres
