COMPOSE_PROJECT_NAME=frienda-dev
# PostgreSQL connection settings (shared by Makefile and Docker Compose)
# PG_HOST is used by Makefile only (psql/pg_dump connect to this host)
# PG_PORT, PG_USER, PG_PASSWORD, PG_DB are used by both Makefile and Docker Compose
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB=postgres

# --- Local Development Services (docker compose --profile services) ---
# Uncomment and change ports below if defaults conflict with your environment.
# Firebase Emulator
# FIREBASE_AUTH_PORT=9099
# FIREBASE_STORAGE_PORT=9199
# FIREBASE_EMULATOR_UI_PORT=4000
# FIREBASE_PROJECT_ID=frienda-local
# Anvil (Blockchain)
# ANVIL_PORT=8545
# Mailpit (SMTP + Web UI)
# MAILPIT_SMTP_PORT=1025
# MAILPIT_UI_PORT=8025
# stripe-mock
# STRIPE_MOCK_PORT=12111
# STRIPE_MOCK_TLS_PORT=12112
# BigQuery Emulator
# BIGQUERY_PORT=9050
# BIGQUERY_PROJECT_ID=frienda-local
# Contentful Mock
# CONTENTFUL_MOCK_PORT=3100
# Gemini Mock
# GEMINI_MOCK_PORT=3101
