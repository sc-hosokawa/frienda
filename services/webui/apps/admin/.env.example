# ===========================================
# WebUI Admin Environment Variables
# ===========================================
# .env.example をコピーして .env.local を作成してください
# cp .env.example .env.local

# --- 基本設定（ローカル開発に必須） ---
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_GRAPHQL_ENDPOINT=http://localhost:8080/graphql

# --- Basic認証（管理画面アクセス制御） ---
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# --- Stripe（サーバーサイド決済） ---
STRIPE_SECRET_KEY=
