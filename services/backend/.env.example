# ===========================================
# Backend Environment Variables
# ===========================================
# .env.example をコピーして .env を作成してください
# cp .env.example .env

# --- 基本設定（ローカル開発に必須） ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres
HOST=0.0.0.0
PORT=8080
ENV=dev
ENVIRONMENT=dev

# --- 認証（Firebase JWT検証） ---
JWK_URL=
JWK_ISSUER=

# --- AI（Gemini） ---
GEMINI_API_KEY=

# --- メール（SendGrid） ---
SENDGRID_API_KEY=

# --- ハッシュ ---
HASH_SALT=

# --- オンチェーン ---
ETH_RPC_URL=
CREDENTIAL_CONTRACT_ADDRESS=

# --- DSP（データサービスプラットフォーム） ---
SCR_SERVICE_ACCOUNT_DSP=
CLIENT_ID=
CLIENT_SECRET=
GENDER_GEN_AUTH_URL=
GENDER_GEN_PLAYBACK_URL=
GENDER_GEN_PLAYBACK_PREFIX=
DSP_QUERY_MONTHLY_TEMPLATE=
SCR_DSP_QUERY_DAILY_TEMPLATE=
SCR_LOCATION=
SCR_DSP_PJ_ID=
