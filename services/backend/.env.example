# ===========================================
# Backend Environment Variables
# ===========================================
# .env.example をコピーして .env を作成してください
# cp .env.example .env

# --- 基本設定（ローカル開発に必須） ---
# docker-compose.yaml の POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB と一致
# ※ 本番環境では必ず適切な接続情報に変更してください
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres
HOST=0.0.0.0
PORT=8080
ENV=dev
ENVIRONMENT=dev

# --- 認証（Firebase JWT検証、機能利用時に必要） ---
JWK_URL=
JWK_ISSUER=
# ローカル開発: Firebase Emulator を使用する場合
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# --- AI（Gemini、機能利用時に必要） ---
GEMINI_API_KEY=
# ローカル開発: Gemini モックサーバーを使用する場合
# GEMINI_API_BASE_URL=http://127.0.0.1:3101

# --- メール（SendGrid、機能利用時に必要） ---
SENDGRID_API_KEY=
# ローカル開発: sendgrid-mock を使用する場合（Mailpit転送: UI http://127.0.0.1:8025）
# SENDGRID_API_BASE_URL=http://127.0.0.1:3102/v3/mail/send
# ローカル開発: Mailpit を直接使用する場合（SMTP: 127.0.0.1:1025）
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1025

# --- ハッシュ（パイプライン機能で必要） ---
HASH_SALT=

# --- オンチェーン（ブロックチェーン機能で必要） ---
ETH_RPC_URL=
CREDENTIAL_CONTRACT_ADDRESS=
# ローカル開発: Anvil を使用する場合
# ETH_RPC_URL=http://127.0.0.1:8545

# --- 決済（Stripe、機能利用時に必要） ---
# ローカル開発: stripe-mock を使用する場合
# STRIPE_API_BASE_URL=http://127.0.0.1:12111

# --- CMS（Contentful、ニュース機能で必要） ---
# ローカル開発: Contentful モックサーバーを使用する場合
# CONTENTFUL_API_BASE_URL=http://127.0.0.1:3100

# --- DSP（データサービスプラットフォーム、DSP機能で必要） ---
SCR_SERVICE_ACCOUNT_DSP=
CLIENT_ID=
CLIENT_SECRET=
GENDER_GEN_AUTH_URL=
GENDER_GEN_PLAYBACK_URL=
GENDER_GEN_PLAYBACK_PREFIX=
DSP_QUERY_MONTHLY_TEMPLATE=
SCR_DSP_QUERY_DAILY_TEMPLATE=
SCR_LOCATION=
SCR_DSP_PJ_ID=
# ローカル開発: BigQuery サンドボックス（無料枠）を使用
# https://cloud.google.com/bigquery/docs/sandbox
# GOOGLE_APPLICATION_CREDENTIALS にサービスアカウントキーのパスを設定
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
